# PayTrail environment configuration.
#
# Copy this file to ".env" (which is gitignored) and fill in your values:
#   cp .env.example .env
# The application loads ".env" automatically on startup, so "mvn spring-boot:run"
# picks it up with no extra steps.
#
# Format notes: this file is parsed as Java properties (KEY=value), not as a shell
# script. Do not use the "export" keyword, do not quote values, and double any
# literal backslashes. The standard MongoDB/Redis URLs below need no escaping.

# MongoDB connection string. Local example shown; replace with your Atlas SRV URI
# (mongodb+srv://user:pass@cluster.mongodb.net/paytrail) if using Atlas.
MONGODB_URI=mongodb://localhost:27017/paytrail

# Redis connection URL (used for processing locks and idempotency keys).
REDIS_URL=redis://localhost:6379

# Paystack secret key used to verify webhook HMAC-SHA512 signatures.
# Set this to test_secret_key_for_demo to exercise the pre-signed webhook request
# in docs/paytrail-api.postman_collection.json without a live Paystack account.
PAYSTACK_SECRET_KEY=test_secret_key_for_demo

# Admin/super key. Sent as X-Api-Key it bypasses merchant scoping on the query API;
# sent as X-Super-Key it authorizes the dev key-seeding endpoint. Choose your own.
SUPER_API_KEY=change-me-super-key

# Optional settings (these have sensible defaults if omitted).
APP_PORT=8080
SCHEDULER_BATCH_SIZE=50
SCHEDULER_INTERVAL_MS=10000
